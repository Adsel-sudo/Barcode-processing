# App runtime
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=dev
LOG_LEVEL=INFO

# Feishu credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional webhook verification / encryption
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Optional custom Feishu OpenAPI base
FEISHU_API_BASE=https://open.feishu.cn/open-apis

# Runtime dirs (Docker volume friendly)
OUTPUT_BASE_DIR=./outputs
TEMP_DIR=./tmp
FEISHU_DEDUPE_DB_PATH=./tmp/feishu_dedupe.sqlite3

# Pipeline runtime behavior
DELETE_SOURCE_ON_SUCCESS=true
DEBUG_PREVIEW_ENABLED=false
